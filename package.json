{
  "name": "sekai-chibi-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.3.5",
    "@pixi/app": "^6.5.10",
    "@pixi/constants": "^6.5.10",
    "@pixi/core": "^6.5.10",
    "@pixi/display": "^6.5.10",
    "@pixi/graphics": "^6.5.10",
    "@pixi/math": "^6.5.10",
    "@pixi/mesh": "^6.5.10",
    "@pixi/mesh-extras": "^6.5.10",
    "@pixi/sprite": "^6.5.10",
    "@pixi/ticker": "^6.5.10",
    "@pixi/utils": "^6.5.10",
    "pixi-spine-base-3": "npm:@pixi-spine/base@3.1.2",
    "pixi-spine-runtime-3.6": "^3.1.3",
    "pixi.js": "^8.18.1",
    "solid-js": "^1.9.13",
    "wasm-imagemagick": "^1.2.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.7"
  }
}
